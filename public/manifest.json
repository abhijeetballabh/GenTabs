{
  "manifest_version": 3,
  "name": "GenTabs",
  "version": "1.0.0",
  "description": "Sweep open tabs into a saved group and close them.",
  "permissions": [
    "tabs",
    "storage",
    "sessions",
    "alarms",
    "notifications",
    "scripting",
    "tabGroups"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  }
}